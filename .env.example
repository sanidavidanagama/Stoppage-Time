# --- Agent Secrets ---
ARENA_KEY=your_arena_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Supabase (LTM + Ledger) ---
ST_SUPABASE_URL=https://your-project.supabase.co
ST_SUPABASE_PUBLISHABLE_KEY=sb_publishable__...
ST_SUPABASE_SECRET_KEY=sb_secret_...

# --- Backend Auth ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_password_here
JWT_SECRET_KEY=your_very_long_random_secret_here_at_least_32_chars

# --- CORS (comma-separated origins) ---
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# --- Server ---
PORT=8000
